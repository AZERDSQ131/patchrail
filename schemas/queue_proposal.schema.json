{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchrail.dev/schemas/queue-proposal.v1.schema.json",
  "title": "PatchRail Queue Proposal",
  "description": "Local patch-plan proposal attached to a PatchRail work item for maintainer review.",
  "type": "object",
  "required": [
    "id",
    "work_item_id",
    "title",
    "summary",
    "patch_plan",
    "risk_level",
    "approval_state",
    "created_at",
    "updated_at",
    "decision_note"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^prp_[0-9a-f]{12}$"
    },
    "work_item_id": {
      "type": "string",
      "pattern": "^prq_[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "patch_plan": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "approval_state": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "decision_note": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
