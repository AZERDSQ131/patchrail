{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchrail.dev/schemas/queue-status.v1.schema.json",
  "title": "PatchRail Queue Status",
  "description": "Local status summary emitted by patchrail queue status and the local queue API /status endpoint.",
  "type": "object",
  "required": [
    "schema_version",
    "queue_schema_version",
    "patchrail_version",
    "db_path",
    "local_first",
    "host_boundary",
    "counts",
    "human_gate_summary",
    "latest_audit_event",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": "patchrail.queue_status.v1"
    },
    "queue_schema_version": {
      "const": "patchrail.queue.v1"
    },
    "patchrail_version": {
      "type": "string",
      "minLength": 1
    },
    "db_path": {
      "type": "string",
      "minLength": 1
    },
    "local_first": {
      "const": true
    },
    "host_boundary": {
      "type": "string",
      "minLength": 1
    },
    "counts": {
      "type": "object",
      "required": [
        "work_items_total",
        "work_items_by_status",
        "work_items_by_approval_state",
        "proposals_total",
        "proposals_by_approval_state",
        "audit_events_total"
      ],
      "properties": {
        "work_items_total": {
          "type": "integer",
          "minimum": 0
        },
        "work_items_by_status": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "work_items_by_approval_state": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "proposals_total": {
          "type": "integer",
          "minimum": 0
        },
        "proposals_by_approval_state": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "audit_events_total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "human_gate_summary": {
      "type": "object",
      "required": [
        "status",
        "pending_work_items",
        "pending_proposals",
        "total_pending_decisions",
        "approved_work_items",
        "rejected_work_items",
        "approved_proposals",
        "rejected_proposals",
        "write_actions_unlocked"
      ],
      "properties": {
        "status": {
          "enum": ["awaiting_human_review", "no_pending_decisions"]
        },
        "pending_work_items": {
          "type": "integer",
          "minimum": 0
        },
        "pending_proposals": {
          "type": "integer",
          "minimum": 0
        },
        "total_pending_decisions": {
          "type": "integer",
          "minimum": 0
        },
        "approved_work_items": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_work_items": {
          "type": "integer",
          "minimum": 0
        },
        "approved_proposals": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_proposals": {
          "type": "integer",
          "minimum": 0
        },
        "write_actions_unlocked": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "latest_audit_event": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "queue-audit-event.v1.schema.json" }
      ]
    },
    "safety": {
      "type": "object",
      "required": [
        "write_actions_allowed_by_default",
        "github_write_permission_required",
        "network_required",
        "external_model_required",
        "billing_required",
        "approval_records_execute_actions"
      ],
      "properties": {
        "write_actions_allowed_by_default": {
          "const": false
        },
        "github_write_permission_required": {
          "const": false
        },
        "network_required": {
          "const": false
        },
        "external_model_required": {
          "const": false
        },
        "billing_required": {
          "const": false
        },
        "approval_records_execute_actions": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
