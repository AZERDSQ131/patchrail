{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchrail.dev/schemas/queue-work-item.v1.schema.json",
  "title": "PatchRail Queue Work Item",
  "description": "Local, human-gated work item emitted by patchrail queue commands and the local queue API.",
  "type": "object",
  "required": [
    "id",
    "kind",
    "title",
    "source",
    "status",
    "approval_state",
    "write_actions_allowed",
    "created_at",
    "updated_at",
    "payload",
    "decision_note"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^prq_[0-9a-f]{12}$"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["open", "pending", "approved", "rejected", "skipped"]
    },
    "approval_state": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "write_actions_allowed": {
      "const": false
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "payload": {
      "type": "object"
    },
    "decision_note": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
