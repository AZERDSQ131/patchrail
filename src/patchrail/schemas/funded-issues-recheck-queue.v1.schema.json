{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchrail.dev/schemas/funded-issues-recheck-queue.v1.schema.json",
  "title": "PatchRail Funded Issues Recheck Queue",
  "description": "Read-only tracker maintenance queue emitted by patchrail funded-issues recheck-queue.",
  "type": "object",
  "required": [
    "schema_version",
    "source_schema_version",
    "read_only",
    "safe_only",
    "blocked_actions",
    "filters",
    "queue_limit",
    "total_loaded",
    "total_scored",
    "queue_rows_before_limit",
    "queue_rows",
    "no_go_archive_rows",
    "priority_counts",
    "action_counts",
    "focus_batch",
    "items",
    "requirements",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "patchrail.funded_issues.recheck_queue.v1"
    },
    "source_schema_version": {
      "const": "patchrail.funded_issues.v1"
    },
    "read_only": {
      "const": true
    },
    "safe_only": {
      "type": "boolean"
    },
    "blocked_actions": {
      "$ref": "#/$defs/blocked_actions"
    },
    "filters": {
      "$ref": "#/$defs/filters"
    },
    "queue_limit": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "total_loaded": {
      "type": "integer",
      "minimum": 0
    },
    "total_scored": {
      "type": "integer",
      "minimum": 0
    },
    "queue_rows_before_limit": {
      "type": "integer",
      "minimum": 0
    },
    "queue_rows": {
      "type": "integer",
      "minimum": 0
    },
    "no_go_archive_rows": {
      "type": "integer",
      "minimum": 0
    },
    "priority_counts": {
      "$ref": "#/$defs/count_map"
    },
    "action_counts": {
      "$ref": "#/$defs/count_map"
    },
    "focus_batch": {
      "$ref": "#/$defs/focus_batch"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recheck_queue_item"
      }
    },
    "requirements": {
      "$ref": "#/$defs/safe_requirements"
    },
    "boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "blocked_actions": {
      "type": "array",
      "contains": { "const": "automatic_claims" },
      "items": {
        "enum": [
          "automatic_claims",
          "automatic_pull_requests",
          "automatic_issue_comments",
          "mass_outreach",
          "ranking_by_money_only"
        ]
      },
      "uniqueItems": true
    },
    "client_profile": {
      "type": "object",
      "required": [
        "schema_version",
        "name",
        "languages",
        "min_usd",
        "allowed_opportunity_states",
        "allowed_risk_levels",
        "excluded_risk_flags",
        "read_only"
      ],
      "properties": {
        "schema_version": {
          "const": "patchrail.funded_issues.client_profile.v1"
        },
        "name": {
          "type": ["string", "null"]
        },
        "languages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "min_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "allowed_opportunity_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/opportunity_state" },
          "uniqueItems": true
        },
        "allowed_risk_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/risk_level" },
          "uniqueItems": true
        },
        "excluded_risk_flags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "count_map": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "filters": {
      "type": "object",
      "required": [
        "profile",
        "platform",
        "language",
        "min_usd",
        "opportunity_state",
        "risk_level"
      ],
      "properties": {
        "profile": {
          "anyOf": [
            { "$ref": "#/$defs/client_profile" },
            { "type": "null" }
          ]
        },
        "platform": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "min_usd": { "type": ["number", "null"], "minimum": 0 },
        "opportunity_state": {
          "anyOf": [
            { "$ref": "#/$defs/opportunity_state" },
            { "type": "null" }
          ]
        },
        "risk_level": {
          "anyOf": [
            { "$ref": "#/$defs/risk_level" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "focus_batch": {
      "type": "object",
      "required": [
        "status",
        "primary_action",
        "priority",
        "item_count",
        "references",
        "platform_counts",
        "evidence_checklist",
        "boundary"
      ],
      "properties": {
        "status": {
          "enum": ["active_recheck_batch", "clear"]
        },
        "primary_action": {
          "enum": [
            "confirm_client_authorization",
            "none",
            "recheck_public_issue_state",
            "recheck_scope_and_noise",
            "verify_funding_visibility"
          ]
        },
        "priority": {
          "enum": ["high", "medium", "low", "none"]
        },
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "references": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "platform_counts": {
          "$ref": "#/$defs/count_map"
        },
        "evidence_checklist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "opportunity_state": {
      "enum": ["active", "closed", "stale", "unknown"]
    },
    "recheck_queue_item": {
      "type": "object",
      "required": [
        "reference",
        "title",
        "url",
        "platform",
        "funding",
        "opportunity_state",
        "risk_level",
        "score",
        "confidence",
        "decision_gate",
        "priority",
        "action",
        "reason",
        "evidence_checklist",
        "recommended_next_step",
        "blocked_actions"
      ],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "platform": { "type": "string", "minLength": 1 },
        "funding": { "type": "string", "minLength": 1 },
        "opportunity_state": { "$ref": "#/$defs/opportunity_state" },
        "risk_level": { "$ref": "#/$defs/risk_level" },
        "score": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "decision_gate": {
          "enum": [
            "go_after_recheck",
            "needs_authorization",
            "needs_funding_verification",
            "watchlist"
          ]
        },
        "priority": {
          "enum": ["high", "medium", "low"]
        },
        "action": {
          "enum": [
            "confirm_client_authorization",
            "recheck_public_issue_state",
            "recheck_scope_and_noise",
            "verify_funding_visibility"
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_checklist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "recommended_next_step": { "type": "string", "minLength": 1 },
        "blocked_actions": { "$ref": "#/$defs/blocked_actions" }
      },
      "additionalProperties": false
    },
    "risk_level": {
      "enum": ["low", "medium", "high"]
    },
    "safe_requirements": {
      "type": "object",
      "required": [
        "network_required",
        "github_write_permission_required",
        "external_model_required",
        "billing_required"
      ],
      "properties": {
        "network_required": { "const": false },
        "github_write_permission_required": { "const": false },
        "external_model_required": { "const": false },
        "billing_required": { "const": false }
      },
      "additionalProperties": false
    }
  }
}
